generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @db.Uuid
  email              String   @unique
  name               String   @default("")
  role               String   @default("Single-trader")
  timezone           String   @default("America/Tegucigalpa")
  baseCurrency       String   @default("USD") @map("base_currency")
  fxRates            String   @default("{}") @map("fx_rates") // per-user FX overrides JSON: { "<CUR>": usdValue }
  language           String   @default("es")
  weeklyGoalMinutes   Int?     @default(300) @map("weekly_goal_minutes")
  emailNotifications  Boolean  @default(true) @map("email_notifications")
  currentStreak       Int      @default(0) @map("current_streak")
  bestStreak          Int      @default(0) @map("best_streak")
  lastReviewDate      DateTime? @map("last_review_date") @db.Date
  weeklyTradesGoal    Int?     @map("weekly_trades_goal")
  weeklyPnlGoal       Decimal? @map("weekly_pnl_goal") @db.Decimal(14, 2)
  disciplineGoal      Int?     @map("discipline_goal")
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  // BIZ-1 (ADR-004, Decisión B): opt-in al aprendizaje agregado anónimo cross-user
  // (el moat). Default false. Reserva la frontera; el modelo poblacional es futuro.
  dataSharingConsent  Boolean  @default(false) @map("data_sharing_consent")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  accounts          Account[]
  setups            Setup[]
  trades            Trade[]
  rules             Rule[]
  weeklyReviews     WeeklyReview[]
  learningResources LearningResource[]
  resourceReviews   ResourceReview[]
  studySessions     StudySession[]
  markets           Market[]
  withdrawals       Withdrawal[]
  accountLogs       AccountLog[]
  tradeEvents       TradeEvent[]
  tradeStatsCache      TradeStatsCache[]
  checklistResults     TradeChecklistResult[]
  tradingSessionLogs   TradingSessionLog[]
  tradeEmbeddings      TradeEmbedding[]
  emailLogs            EmailLog[]
  preferences          UserPreferences?
  aiConfigs            UserAiConfig[]
  aiSettings           UserAiSettings?
  monthlyReviews       MonthlyReview[]
  monthlyGoals         MonthlyGoal[]
  notifications            Notification[]
  notificationPreferences  NotificationPreference[]
  tags                     Tag[]
  automations              Automation[]
  customPalettes           CustomPalette[]
  domainEvents             DomainEvent[]
  insights                 Insight[]
  commitments              Commitment[]
  commitmentChecks         CommitmentCheck[]
  reinforcements           Reinforcement[]
  ruleSuggestions          RuleSuggestion[]
  coachThreads             CoachThread[]
  coachMessages            CoachMessage[]
  coachMemory              CoachMemory[]

  @@map("users")
}

// ─────────────────────────────────────────────
// USER AI SETTINGS (expanded AI configuration)
// Per-feature model routing + global default + global fallback + cost posture.
// ─────────────────────────────────────────────
model UserAiSettings {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @map("user_id") @db.Uuid
  defaultProvider  String   @default("anthropic") @map("default_provider")  // openrouter | anthropic | openai
  defaultModel     String   @default("claude-sonnet-4-6") @map("default_model")
  fallbackProvider String?  @map("fallback_provider")
  fallbackModel    String?  @map("fallback_model")
  costPriority     String   @default("quality") @map("cost_priority")        // quality | speed | cost
  featureModels    Json     @default("{}") @map("feature_models")            // { [feature]: { provider, model } }
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_ai_settings")
}

// ─────────────────────────────────────────────
// ACCOUNT
// type:    PERSONAL | PROP_FIRM | DEMO_PERSONAL | DEMO_PROP | BACKTEST | QA
// status:  ACTIVE | PAUSED | INACTIVE | LOST
// ddModel: FIXED | TRAILING  (prop firms only)
// phase:   PHASE_1 | PHASE_2 | FUNDED | NONE
// ─────────────────────────────────────────────
model Account {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String
  broker         String
  type           String   @default("PERSONAL")
  status         String   @default("ACTIVE")                // ACTIVE | PAUSED | INACTIVE | LOST
  statusNote     String   @default("") @map("status_note")  // required note when LOST
  initialBalance Decimal  @default(0) @map("initial_balance") @db.Decimal(14, 2)
  currency       String   @default("USD")
  timezone       String   @default("America/New_York")

  // ── Drawdown limits (all account types) ──────
  ddDailyPct    Decimal? @map("dd_daily_pct")   @db.Decimal(5, 2)
  ddWeeklyPct   Decimal? @map("dd_weekly_pct")  @db.Decimal(5, 2)
  ddMonthlyPct  Decimal? @map("dd_monthly_pct") @db.Decimal(5, 2)
  ddTotalPct    Decimal? @map("dd_total_pct")   @db.Decimal(5, 2)

  // ── Profit target (all account types) ────────
  targetPct     Decimal? @map("target_pct")     @db.Decimal(5, 2)

  // ── Leverage (margin calculator) ──────────────
  maxLeverage    Int? @map("max_leverage")     // broker max, e.g. 30 for 1:30
  targetLeverage Int? @map("target_leverage")  // healthy effective-leverage target

  // ── Prop Firm extras ──────────────────────────
  ddModel           String?  @default("FIXED")   @map("dd_model")            // FIXED | TRAILING
  phase             String?  @default("PHASE_1") @map("phase")               // PHASE_1 | PHASE_2 | FUNDED | NONE
  maxTradesPerDay   Int?     @map("max_trades_per_day")
  allowedSymbols    String[] @map("allowed_symbols")
  minTradingDays    Int?     @map("min_trading_days")                        // some firms require min days

  // ── Risk-limit lock (HALLAZGO 1B) ─────────────
  // When a configured loss limit (daily/weekly/monthly) is reached the account
  // is locked: no new trades or imports until manually unlocked.
  locked      Boolean   @default(false)
  lockReason  String    @default("") @map("lock_reason")  // e.g. "DAILY_LOSS_LIMIT"
  lockedAt    DateTime? @map("locked_at")

  // ── Balance sync (broker reconciliation) ──────
  // Last broker balance entered via "Sincronizar balance" + when. Equity itself
  // is still derived (initial + P&L + adjustments); these are for display/audit.
  lastSyncedBalance Decimal?  @map("last_synced_balance") @db.Decimal(14, 2)
  lastSyncedAt      DateTime? @map("last_synced_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades        Trade[]
  weeklyReviews WeeklyReview[]
  withdrawals   Withdrawal[]
  logs          AccountLog[]

  @@index([userId])
  @@map("accounts")
}

// ─────────────────────────────────────────────
// WITHDRAWAL
// status: SOLICITADO | EN_PROCESO | PAGADO | RECHAZADO
// ─────────────────────────────────────────────
model Withdrawal {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  accountId String   @map("account_id") @db.Uuid
  amount    Decimal  @db.Decimal(14, 2)
  currency  String   @default("USD")
  status    String   @default("SOLICITADO")   // SOLICITADO | EN_PROCESO | PAGADO | RECHAZADO
  date      DateTime @db.Date
  note      String   @default("")
  reference String   @default("")              // transaction id / comprobante
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId, date(sort: Desc)])
  @@index([accountId])
  @@map("withdrawals")
}

// ─────────────────────────────────────────────
// ACCOUNT LOG  — immutable event trail
// event: CREATED | PHASE_CHANGE | WITHDRAWAL | STATUS_CHANGE | NOTE
// ─────────────────────────────────────────────
model AccountLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  accountId String   @map("account_id") @db.Uuid
  event     String                              // CREATED | PHASE_CHANGE | WITHDRAWAL | STATUS_CHANGE | NOTE
  payload   Json     @default("{}")             // flexible: { from, to, amount, note, … }
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt(sort: Desc)])
  @@map("account_logs")
}

model Setup {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  name              String
  abbreviation      String
  market            String   @default("")
  direction         String   @default("AMBAS")
  status            String   @default("ACTIVO")
  description       String   @default("")
  color             String   @default("#4f6ef7")
  images            String[] @default([])
  aplusChecklist    String[] @map("aplus_checklist")
  standardChecklist String[] @map("standard_checklist")
  // ── Edge definition fields (T-VIII-002) ──────
  expectedWr        Decimal? @map("expected_wr")    @db.Decimal(5,2)
  expectedAvgR      Decimal? @map("expected_avg_r") @db.Decimal(5,3)
  minR              Decimal? @map("min_r")          @db.Decimal(5,3)
  maxR              Decimal? @map("max_r")          @db.Decimal(5,3)
  edgeUpdatedAt     DateTime? @map("edge_updated_at") @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]
  linkedResources LearningResource[] @relation("ResourceSetups")
  versions SetupVersion[]

  @@map("setups")
}

model Trade {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  accountId      String   @map("account_id") @db.Uuid
  setupId        String?  @map("setup_id") @db.Uuid
  direction      String
  symbol         String
  entry          Decimal  @db.Decimal(16, 5)
  stop           Decimal  @db.Decimal(16, 5)
  target         Decimal  @db.Decimal(16, 5)
  size           Decimal  @db.Decimal(12, 4)
  date           DateTime @db.Date
  openTime       String   @map("open_time")
  session        String
  tags           String[]
  notes          String   @default("")
  screenshotUrls String[] @map("screenshot_urls")
  rMultiple      Decimal? @map("r_multiple") @db.Decimal(8, 3)
  pnl            Decimal? @db.Decimal(14, 2)
  status         String   @default("OPEN")
  closePrice     Decimal? @map("close_price") @db.Decimal(16, 5)
  closeTime      String?  @map("close_time")
  commission     Decimal? @db.Decimal(10, 2)
  importTicket   String?  @map("import_ticket")
  // ── Psychology fields (Sprint 4, TASK-034) ──────────────
  emotionBefore    String?  @map("emotion_before")    // "calm" | "anxious" | "excited" | "fearful" | "overconfident"
  confidenceRating Int?     @map("confidence_rating") // 1–5
  executionQuality Int?     @map("execution_quality") // 1–5
  fomoFlag         Boolean  @default(false) @map("fomo_flag")
  revengeFlag      Boolean  @default(false) @map("revenge_flag")
  planNotes        String?  @map("plan_notes") @db.VarChar(500)
  // ── Capture v3 (Sprint 2, C7 / FREEZE-E1) ───────────────
  riskPct          Decimal? @map("risk_pct") @db.Decimal(6, 3) // derived from entry/stop/size/balance (#27)
  maeR             Decimal? @map("mae_r") @db.Decimal(8, 3)    // max adverse excursion in R (#35)
  mfeR             Decimal? @map("mfe_r") @db.Decimal(8, 3)    // max favorable excursion in R (#35)
  regime           String?  // trend | range | volatile (E5.C6, manual v3.0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  setup   Setup?       @relation(fields: [setupId], references: [id], onDelete: SetNull)
  events  TradeEvent[]
  embedding TradeEmbedding?

  @@index([userId, date(sort: Desc)])
  @@index([userId, status, date(sort: Desc)])
  @@index([accountId])
  @@map("trades")

  checklistResult TradeChecklistResult?
}

model TradeEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tradeId   String   @map("trade_id") @db.Uuid
  type      String   // STOP_MOVE | PARTIAL_CLOSE | SCALE_IN | NOTE
  price     Decimal? @db.Decimal(16, 5)
  contracts Decimal? @db.Decimal(12, 4)
  notes     String   @default("")
  timestamp DateTime @default(now())

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@map("trade_events")
}

// UNIFIED Rule (v3.1 Sprint 1 — C6, FREEZE-E2/D8/D9).
// v2 split rules into descriptive `Rule` + executable `Automation`. v3 unifies them
// into one model with `mode: enforce | warn`. The executable fields (trigger/
// conditions/actions/priority/category/lastFiredAt) are ADDED here; `Automation`
// rows are backfilled into this table (source_automation_id) by the S1 migration,
// non-destructively. ENFORCEMENT still runs off `Automation` until the cutover is
// verified at gate G2 (FREEZE-P9) — see DECISIONS_SPRINT_1. source_commitment_id /
// source_insight_id are provenance for the Behavior Engine (S4/S5); plain uuids
// (no FK) since Commitment does not exist yet.
model Rule {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  description String   @default("")
  severity    String   @default("CRÍTICA")
  isSystem    Boolean  @default(false) @map("is_system")
  enabled     Boolean  @default(true)
  mode        String   @default("warn") // enforce | warn
  trigger     String? // TRADE_PRE_CREATE | TRADE_CREATED | TRADE_CLOSED | TRADE_UPDATED | null (descriptive)
  conditions  Json     @default("{}")
  actions     Json     @default("[]")
  priority    Int      @default(0)
  category    String   @default("")
  lastFiredAt DateTime? @map("last_fired_at")
  sourceAutomationId String? @map("source_automation_id") @db.Uuid
  sourceCommitmentId String? @map("source_commitment_id") @db.Uuid
  sourceInsightId    String? @map("source_insight_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  commitments Commitment[]
  ruleSuggestions RuleSuggestion[]

  @@index([userId])
  @@index([sourceAutomationId])
  @@map("rules")
}

// ─────────────────────────────────────────────
// TAG  (Epic 2 — metadata catalog keyed by name)
// Trades keep `tags String[]`; the `name` is the join key. This table decorates
// those strings with color/icon/category/order/displayMode.
// displayMode: icon_color | dot | text
// semantic:    violation | quality | null   (drives analytics meaning; system tags)
// System tags (Off-plan/Impulsivo/Revanche = violation; A+ = quality) are seeded
// with isSystem=true and their name is locked (renaming would break analytics).
// ─────────────────────────────────────────────
model Tag {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  color       String   @default("#6b7280")
  icon        String?
  description String   @default("")
  category    String   @default("")
  displayMode String   @default("icon_color") @map("display_mode")
  sortOrder   Int      @default(0) @map("sort_order")
  isSystem    Boolean  @default(false) @map("is_system")
  semantic    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

// ─────────────────────────────────────────────
// AUTOMATION  (Epic 3 — WHEN/IF/THEN rules engine)
// trigger:    TRADE_PRE_CREATE | TRADE_CREATED | TRADE_CLOSED | TRADE_UPDATED
// conditions: ConditionNode tree (JSON). {} = always.
// actions:    RuleAction[] (JSON). See domains/rules/.
// Pre-trade rules run synchronously and may BLOCK the operation; post-trade rules
// react (notify/tag) best-effort. The hardcoded risk-enforcement is independent.
// ─────────────────────────────────────────────
model Automation {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  name        String
  description String    @default("")
  enabled     Boolean   @default(true)
  priority    Int       @default(0)
  trigger     String
  conditions  Json      @default("{}")
  actions     Json      @default("[]")
  category    String    @default("")
  isSystem    Boolean   @default(false) @map("is_system")
  lastFiredAt DateTime? @map("last_fired_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, trigger, enabled])
  @@map("automations")
}

// ─────────────────────────────────────────────
// NOTIFICATION  (Epic 1 — event-sourced)
// type:     SUCCESS | INFO | WARNING | ERROR | CRITICAL | TRADING_ALERT
// priority: P0 | P1 | P2 | P3
// category: Cuenta | Reglas | Reviews | Aprendizaje | Trading | Sistema
// `code` references the central message catalog (lib/messages/catalog.ts).
// Dedupe: a partial UNIQUE index on (user_id, dedupe_key) WHERE dedupe_key IS NOT
// NULL is created in the migration SQL (Prisma can't express partial indexes).
// ─────────────────────────────────────────────
model Notification {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  code       String
  type       String
  priority   String
  category   String
  title      String
  body       String    @default("")
  params     Json      @default("{}")
  href       String?
  actions    Json      @default("[]")
  channel    String    @default("in_app")
  dedupeKey  String?   @map("dedupe_key")
  groupKey   String?   @map("group_key")
  sourceId   String?   @map("source_id")
  readAt     DateTime? @map("read_at")
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@map("notifications")
}

model NotificationPreference {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  category    String
  channels    String[] @default(["in_app"])
  minPriority String   @default("P3") @map("min_priority")
  muted       Boolean  @default(false)
  quietStart  String?  @map("quiet_start")
  quietEnd    String?  @map("quiet_end")
  timezone    String   @default("America/New_York")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("notification_preferences")
}

// ─────────────────────────────────────────────
// SETUP VERSION (T-VIII-004)
// Immutable snapshot of a setup before edits to
// versioned fields (aplusChecklist, standardChecklist, direction).
// ─────────────────────────────────────────────
model SetupVersion {
  id        String   @id @default(uuid()) @db.Uuid
  setupId   String   @map("setup_id") @db.Uuid
  version   Int
  snapshot  Json
  reason    String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  setup Setup @relation(fields: [setupId], references: [id], onDelete: Cascade)

  @@unique([setupId, version])
  @@map("setup_versions")
}

model WeeklyReview {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  accountId        String?  @map("account_id") @db.Uuid
  weekLabel        String   @map("week_label")
  weekRange        String   @map("week_range")
  weekStart        DateTime @map("week_start") @db.Date
  weekEnd          DateTime @map("week_end") @db.Date
  tradeCount       Int      @default(0) @map("trade_count")
  netPnl           Decimal  @default(0) @map("net_pnl") @db.Decimal(14, 2)
  winRate          Decimal  @default(0) @map("win_rate") @db.Decimal(5, 2)
  disciplineScore  Int      @default(0) @map("discipline_score")
  executiveSummary String   @default("") @map("executive_summary")
  whatWorked       String   @default("") @map("what_worked")
  toImprove        String   @default("") @map("to_improve")
  status           String   @default("draft")
  aiAnalysis       String?   @map("ai_analysis") @db.Text
  aiAnalysisAt     DateTime? @map("ai_analysis_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, weekStart(sort: Desc)])
  @@map("weekly_reviews")
}

model LearningResource {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  title           String
  type            String
  author          String    @default("")
  source          String    @default("")
  date            DateTime  @db.Date
  notes           String    @default("")
  tags            String[]
  markedForReview Boolean   @default(false) @map("marked_for_review")
  progressPct     Int?      @map("progress_pct")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // New fields (TASK-L003)
  status          String    @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | IN_REVIEW | MASTERED | ABANDONED
  progressType    String?   @map("progress_type") // manual | pages | minutes | sessions
  totalUnits      Int?      @map("total_units")
  currentUnits    Int?      @map("current_units")
  avgScore        Decimal?  @map("avg_score") @db.Decimal(5, 2)
  nextReviewAt    DateTime? @map("next_review_at") @db.Date
  reviewInterval  Int?      @map("review_interval")
  isFavorite      Boolean   @default(false) @map("is_favorite")
  rating          Int?
  completedAt     DateTime? @map("completed_at")
  weekDeltaMinutes Int      @default(0) @map("week_delta_minutes")
  weekDeltaResetAt DateTime? @map("week_delta_reset_at")
  archiveReason   String?   @map("archive_reason") // "irrelevant" | "mastered" | "no_time"

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews       ResourceReview[]
  studySessions StudySession[]
  linkedSetups  Setup[]          @relation("ResourceSetups")

  @@index([userId, date(sort: Desc)])
  @@map("learning_resources")
}

// Aprendizaje SP1 — timed study blocks (active while running, completed when
// finished, or planned for a future date). Distinct from SRS reviews.
model StudySession {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  resourceId  String    @map("resource_id") @db.Uuid
  status      String    @default("active") // active | completed | planned
  source      String    @default("focus")  // focus | manual | planned
  startedAt   DateTime  @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")
  durationMin Int?      @map("duration_min")
  plannedMin  Int?      @map("planned_min")
  note        String    @default("")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt(sort: Desc)])
  @@index([resourceId])
  @@map("study_sessions")
}

model ResourceReview {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  resourceId   String   @map("resource_id") @db.Uuid
  learned      String   @default("")
  howToApply   String   @default("") @map("how_to_apply")
  insights     String[]
  rating       Int      @default(0)
  masteryLevel Int      @default(1) @map("mastery_level")
  reviewType   String   @default("manual") @map("review_type")
  nextReviewAt DateTime @db.Date @map("next_review_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([userId, nextReviewAt])
  @@index([resourceId])
  @@map("resource_reviews")
}

model Market {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  symbol        String
  name          String
  category      String
  exchange      String   @default("")
  tickSize      String   @default("") @map("tick_size")
  pointValue    String   @default("") @map("point_value")
  currency      String   @default("USD")
  sessions      String[]
  description   String   @default("")
  isWatchlisted Boolean  @default(false) @map("is_watchlisted")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@map("markets")
}

// ─────────────────────────────────────────────
// TRADE STATS CACHE
// Materialized analytics cache (T-IV-004).
// Keyed by (user_id, period) where period is
// the dashboardStats period enum value.
// TTL enforced at application layer (5 min).
// Feature-flagged via ANALYTICS_CACHE_ENABLED=true.
// ─────────────────────────────────────────────
model TradeStatsCache {
  userId     String   @map("user_id") @db.Uuid
  period     String
  accountId  String?  @map("account_id") @db.Uuid
  statsJson  Json     @map("stats_json")
  computedAt DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, period])
  @@index([userId])
  @@map("trade_stats_cache")
}

// ─────────────────────────────────────────────
// TRADE CHECKLIST RESULT (T-V-003)
// Stores which A+/standard checklist items were
// checked before entering a trade.
// ─────────────────────────────────────────────
model TradeChecklistResult {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  tradeId      String   @unique @map("trade_id") @db.Uuid
  setupId      String?  @map("setup_id") @db.Uuid
  itemsChecked String[] @map("items_checked")
  itemsTotal   Int      @map("items_total")
  createdAt    DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("trade_checklist_results")
}

// ─────────────────────────────────────────────
// TRADING SESSION LOG (T-V-004)
// Pre-session mood and energy ratings (1-5).
// Unique per (user, date, session).
// ─────────────────────────────────────────────
model TradingSessionLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  date        DateTime @db.Date
  session     String
  preMood     Int?     @map("pre_mood")
  energyLevel Int?     @map("energy_level")
  notes       String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, session])
  @@index([userId])
  @@map("trading_sessions")
}

// ─────────────────────────────────────────────
// TRADE EMBEDDING (Phase XIII)
// Tracks embedding vector state per trade. Actual vector stored in pgvector.
// Deferred: EmbeddingService requires UserAiConfig (Phase XI) for key resolution.
// ─────────────────────────────────────────────
model TradeEmbedding {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  tradeId     String   @unique @map("trade_id") @db.Uuid
  model       String
  notesHash   String   @map("notes_hash")
  embeddedAt  DateTime @default(now()) @map("embedded_at")

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("trade_embeddings")
}

// ─────────────────────────────────────────────
// USER PREFERENCES (Sprint 4, TASK-030)
// Per-user UI preferences persisted server-side.
// Created on first update via upsert.
// ─────────────────────────────────────────────
model UserPreferences {
  userId       String   @id @map("user_id") @db.Uuid
  theme        String   @default("system")      // "light" | "dark" | "system"
  colorTheme   String   @default("indigo")      @map("color_theme") // "indigo" | "violeta" | "turquesa" | "carmesi" | "custom"
  customTheme  String?  @map("custom_theme")    // JSON: { accent, accentSoft, ... } when colorTheme = "custom"
  accentHue    Int?     @map("accent_hue")      // 0–360 OKLCH (legacy quick accent override)
  colorScheme  String   @default("default")     @map("color_scheme") // "default" | "deuteranopia" | "mono"
  defaultTab   String   @default("portfolio")   @map("default_tab")
  kpiOrder     String[] @default([]) @map("kpi_order")
  kpiHidden    String[] @default([]) @map("kpi_hidden")
  defaultGrain String   @default("daily")       @map("default_grain")
  tableDensity String   @default("comfortable") @map("table_density")
  dateFormat   String   @default("DD/MM/YYYY")  @map("date_format")
  numberLocale String   @default("es-HN")       @map("number_locale")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─────────────────────────────────────────────
// CUSTOM PALETTE (theme system · full-palette redesign)
// A user's saved palette library. config = PaletteConfig JSON (see src/lib/theme).
// Selected via user_preferences.color_theme = "custom:<id>". Limit (10) enforced
// in the tRPC router, not the DB.
// ─────────────────────────────────────────────
model CustomPalette {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  config    Json
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("custom_palette")
}

// ─────────────────────────────────────────────
// EMAIL LOG (Phase XII)
// Prevents duplicate weekly email sends per user/type/week.
// ─────────────────────────────────────────────
model EmailLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emailType String   @map("email_type")
  weekKey   String   @map("week_key")
  sentAt    DateTime @default(now()) @map("sent_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, emailType, weekKey])
  @@map("email_log")
}

// ─────────────────────────────────────────────
// MONTHLY REVIEW (Sprint 8, TASK-071)
// One review per (user, year, month).
// Aggregates across weekly reviews of that month.
// ─────────────────────────────────────────────
model MonthlyReview {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  year         Int
  month        Int      // 1–12
  summary      String   @default("") @db.Text
  keyThemes    String[] @map("key_themes")
  goalsSet     String[] @map("goals_set")
  goalsMet     String[] @map("goals_met")
  overallScore Int?     @map("overall_score") // 0–100, avg of weekly discipline scores
  weeklyIds    String[] @map("weekly_ids")    // soft refs to WeeklyReview.id
  status       String   @default("draft")     // draft | submitted
  aiAnalysis   String?   @map("ai_analysis") @db.Text
  aiAnalysisAt DateTime? @map("ai_analysis_at")
  // "Carta del Gestor" redesign (2026-06): editorial letter + structured themes + pillar scores.
  letterTitle       String? @map("letter_title")
  keyThemesRich     Json?   @map("key_themes_rich") // [{ title, sentiment: 'up'|'down'|'warn', impact }]
  pillarPerformance Int?    @map("pillar_performance") // 0–100
  pillarDiscipline  Int?    @map("pillar_discipline")
  pillarPsychology  Int?    @map("pillar_psychology")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId, year])
  @@map("monthly_reviews")
}

/**
 * A monthly "commitment" (goal). Rich replacement for MonthlyReview.goalsSet/goalsMet:
 * status (pending/partial/done) + note + recurrence. Goals carry forward month to month
 * and are evaluated by the AI (status proposed) unless the user confirmed them.
 */
model MonthlyGoal {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  year          Int
  month         Int      // 1–12
  text          String
  status        String   @default("pending") // pending | partial | done
  note          String   @default("")
  source        String   @default("user")    // user | ai
  userConfirmed Boolean  @default(false) @map("user_confirmed")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, year, month])
  @@map("monthly_goals")
}

// ─────────────────────────────────────────────
// USER AI CONFIG (Sprint 5)
// Stores encrypted API keys for AI providers per user.
// Supports anthropic | openrouter | openai.
// apiKeyEnc format: "<iv_hex>:<tag_hex>:<ciphertext_hex>" (AES-256-GCM)
// ─────────────────────────────────────────────
model UserAiConfig {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  provider  String   // "anthropic" | "openrouter" | "openai"
  apiKeyEnc String   @map("api_key_enc")  // AES-256-GCM encrypted: "<iv_hex>:<tag_hex>:<ciphertext_hex>"
  model     String?  // optional model override per provider
  isActive  Boolean  @default(true) @map("is_active")
  lastTested DateTime? @map("last_tested")
  errorLog  String?  @map("error_log")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("user_ai_configs")
}

// ─────────────────────────────────────────────
// DOMAIN EVENT (v3.1 Sprint 0 — Cognitive Engine outbox)
// Transactional outbox backbone (ADR-001, FREEZE-D1/D6, entity E5).
// Every domain mutation writes an event row in its own transaction; a dispatcher
// claims pending rows and runs handlers (at-least-once + idempotent). Consumers
// are wired in later sprints — S0 ships the transport only.
// Partial indexes (pending hot-path, dedupe) + RLS live in the SQL migration.
// ─────────────────────────────────────────────
model DomainEvent {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  type        String // one of DOMAIN_EVENT_TYPES (FREEZE-EV catalog)
  payload     Json      @default("{}")
  status      String    @default("pending") // pending | processing | processed | failed
  attempts    Int       @default(0)
  maxAttempts Int       @default(5) @map("max_attempts")
  dedupeKey   String?   @map("dedupe_key")
  occurredAt  DateTime  @default(now()) @map("occurred_at")
  processedAt DateTime? @map("processed_at")
  lastError   String?   @map("last_error")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("domain_events")
}

// ─────────────────────────────────────────────
// INSIGHT (v3.1 Sprint 0 — persisted insights, C8 / FREEZE-E6)
// v2 recomputed insights per-request and threw them away. v3 persists them so
// "did this get better or worse?" is answerable, and so the feed/intervention can
// reference them. Carries statistical-honesty fields (ADR-002): sample_size is
// always real; confidence/credible interval/effect_size stay null until the
// Bayesian estimator lands in S3. One ACTIVE row per (user, fingerprint); resolved
// rows are kept as history (unique partial index in the SQL migration).
// ─────────────────────────────────────────────
model Insight {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @map("user_id") @db.Uuid
  fingerprint          String // stable identity across runs, e.g. "type:scope"
  type                 String
  category             String
  severity             String
  title                String
  detail               String
  evidence             String
  recommendation       String?
  metric               Float?
  sampleSize           Int       @default(0) @map("sample_size")
  confidence           Float?
  credibleIntervalLow  Float?    @map("credible_interval_low")
  credibleIntervalHigh Float?    @map("credible_interval_high")
  effectSize           Float?    @map("effect_size")
  windowFrom           DateTime? @map("window_from") @db.Date
  windowTo             DateTime? @map("window_to") @db.Date
  status               String    @default("active") // active | resolved | committed
  sourceDetector       String?   @map("source_detector")
  createdAt            DateTime  @default(now()) @map("created_at")
  lastSeenAt           DateTime  @default(now()) @map("last_seen_at")
  resolvedAt           DateTime? @map("resolved_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  commitments Commitment[]
  ruleSuggestions RuleSuggestion[]

  @@index([userId, status])
  @@map("insights")
}

// ─────────────────────────────────────────────
// BEHAVIOR ENGINE (Sprint 4 — the loop, C5)
// INSIGHT → COMMITMENT → (RULE) → CHECK → REINFORCEMENT. Structured/anonymizable
// fields (ADR-004): metricKey/target/comparator/result/observedValue carry the
// signal without PII. Migration 20260626120000.
// ─────────────────────────────────────────────
model Commitment {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  sourceInsightId String?   @map("source_insight_id") @db.Uuid
  text            String
  metricKey       String    @map("metric_key")
  target          Float     @default(0)
  comparator      String    @default("<=") // '<=' | '>=' | '=='
  window          String    @default("week") // day | week | month
  startAt         DateTime  @default(now()) @map("start_at")
  endAt           DateTime  @map("end_at")
  ruleId          String?   @map("rule_id") @db.Uuid
  status          String    @default("active") // active | kept | partial | broken | expired
  createdVia      String    @default("self") @map("created_via") // coach | self | review
  keptCount       Int       @default(0) @map("kept_count")
  archivedAt      DateTime? @map("archived_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceInsight Insight?          @relation(fields: [sourceInsightId], references: [id], onDelete: SetNull)
  rule          Rule?             @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  checks        CommitmentCheck[]
  reinforcements Reinforcement[]

  @@index([userId, status])
  @@index([sourceInsightId])
  @@map("commitments")
}

model CommitmentCheck {
  id            String   @id @default(uuid()) @db.Uuid
  commitmentId  String   @map("commitment_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  evaluatedAt   DateTime @default(now()) @map("evaluated_at")
  observedValue Float    @map("observed_value")
  result        String // kept | partial | broken
  evidence      Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")

  commitment Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([commitmentId])
  @@index([userId])
  @@map("commitment_checks")
}

model Reinforcement {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  commitmentId String    @map("commitment_id") @db.Uuid
  kind         String // positive | corrective
  visible      Boolean   @default(true)
  channel      String    @default("today") // today | coach | review
  shownAt      DateTime? @map("shown_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  commitment Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([commitmentId])
  @@map("reinforcements")
}

// RuleSuggestion (E10, S5) — proposed enforce rule for a critical insight.
// proposedRule json/reason carry no PII (anonymizable, ADR-004). Migration 20260626180000.
model RuleSuggestion {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  insightId    String?  @map("insight_id") @db.Uuid
  proposedRule Json     @map("proposed_rule")
  reason       String   @default("")
  status       String   @default("pending") // pending | accepted | dismissed
  ruleId       String?  @map("rule_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  insight Insight? @relation(fields: [insightId], references: [id], onDelete: SetNull)
  rule    Rule?    @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([insightId])
  @@map("rule_suggestions")
}

// ─────────────────────────────────────────────
// COACH v3 (Sprint 6 — memory + threads, C2)
// CoachMemory carries the anti-poisoning frontier (ADR-003 / FREEZE-D9): the LLM
// only writes status='candidate'/source='llm'; 'confirmed' comes from the user (or
// deterministic support) and is the only status injected into the prompt.
// Migration 20260626200000.
// ─────────────────────────────────────────────
model CoachThread {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  title         String   @default("Conversación")
  summary       String?
  createdAt     DateTime @default(now()) @map("created_at")
  lastMessageAt DateTime @default(now()) @map("last_message_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages CoachMessage[]
  memories CoachMemory[]

  @@index([userId, lastMessageAt(sort: Desc)])
  @@map("coach_threads")
}

model CoachMessage {
  id        String   @id @default(uuid()) @db.Uuid
  threadId  String   @map("thread_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String // user | assistant
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  thread CoachThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("coach_messages")
}

model CoachMemory {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  kind           String    @default("fact") // fact | preference | identity
  content        String
  status         String    @default("candidate") // candidate | confirmed | refuted
  source         String    @default("llm") // llm | user | system
  confidence     Float?
  sourceThreadId String?   @map("source_thread_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  expiresAt      DateTime? @map("expires_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceThread CoachThread? @relation(fields: [sourceThreadId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@map("coach_memory")
}

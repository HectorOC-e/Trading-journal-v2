generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @db.Uuid
  email              String   @unique
  name               String   @default("")
  role               String   @default("Single-trader")
  timezone           String   @default("America/Tegucigalpa")
  baseCurrency       String   @default("USD") @map("base_currency")
  language           String   @default("es")
  weeklyGoalMinutes   Int?     @default(300) @map("weekly_goal_minutes")
  emailNotifications  Boolean  @default(true) @map("email_notifications")
  currentStreak       Int      @default(0) @map("current_streak")
  bestStreak          Int      @default(0) @map("best_streak")
  lastReviewDate      DateTime? @map("last_review_date") @db.Date
  weeklyTradesGoal    Int?     @map("weekly_trades_goal")
  weeklyPnlGoal       Decimal? @map("weekly_pnl_goal") @db.Decimal(14, 2)
  disciplineGoal      Int?     @map("discipline_goal")
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  accounts          Account[]
  setups            Setup[]
  trades            Trade[]
  rules             Rule[]
  weeklyReviews     WeeklyReview[]
  learningResources LearningResource[]
  resourceReviews   ResourceReview[]
  markets           Market[]
  withdrawals       Withdrawal[]
  accountLogs       AccountLog[]
  tradeEvents       TradeEvent[]
  tradeStatsCache      TradeStatsCache[]
  checklistResults     TradeChecklistResult[]
  tradingSessionLogs   TradingSessionLog[]
  tradeEmbeddings      TradeEmbedding[]
  emailLogs            EmailLog[]
  preferences          UserPreferences?
  aiConfigs            UserAiConfig[]
  monthlyReviews       MonthlyReview[]

  @@map("users")
}

// ─────────────────────────────────────────────
// ACCOUNT
// type:    PERSONAL | PROP_FIRM | DEMO_PERSONAL | DEMO_PROP | BACKTEST | QA
// status:  ACTIVE | PAUSED | INACTIVE | LOST
// ddModel: FIXED | TRAILING  (prop firms only)
// phase:   PHASE_1 | PHASE_2 | FUNDED | NONE
// ─────────────────────────────────────────────
model Account {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String
  broker         String
  type           String   @default("PERSONAL")
  status         String   @default("ACTIVE")                // ACTIVE | PAUSED | INACTIVE | LOST
  statusNote     String   @default("") @map("status_note")  // required note when LOST
  initialBalance Decimal  @default(0) @map("initial_balance") @db.Decimal(14, 2)
  currency       String   @default("USD")
  timezone       String   @default("America/New_York")

  // ── Drawdown limits (all account types) ──────
  ddDailyPct    Decimal? @map("dd_daily_pct")   @db.Decimal(5, 2)
  ddWeeklyPct   Decimal? @map("dd_weekly_pct")  @db.Decimal(5, 2)
  ddMonthlyPct  Decimal? @map("dd_monthly_pct") @db.Decimal(5, 2)
  ddTotalPct    Decimal? @map("dd_total_pct")   @db.Decimal(5, 2)

  // ── Profit target (all account types) ────────
  targetPct     Decimal? @map("target_pct")     @db.Decimal(5, 2)

  // ── Prop Firm extras ──────────────────────────
  ddModel           String?  @default("FIXED")   @map("dd_model")            // FIXED | TRAILING
  phase             String?  @default("PHASE_1") @map("phase")               // PHASE_1 | PHASE_2 | FUNDED | NONE
  maxTradesPerDay   Int?     @map("max_trades_per_day")
  allowedSymbols    String[] @map("allowed_symbols")
  minTradingDays    Int?     @map("min_trading_days")                        // some firms require min days

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades        Trade[]
  weeklyReviews WeeklyReview[]
  withdrawals   Withdrawal[]
  logs          AccountLog[]

  @@index([userId])
  @@map("accounts")
}

// ─────────────────────────────────────────────
// WITHDRAWAL
// status: SOLICITADO | EN_PROCESO | PAGADO | RECHAZADO
// ─────────────────────────────────────────────
model Withdrawal {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  accountId String   @map("account_id") @db.Uuid
  amount    Decimal  @db.Decimal(14, 2)
  currency  String   @default("USD")
  status    String   @default("SOLICITADO")   // SOLICITADO | EN_PROCESO | PAGADO | RECHAZADO
  date      DateTime @db.Date
  note      String   @default("")
  reference String   @default("")              // transaction id / comprobante
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId, date(sort: Desc)])
  @@index([accountId])
  @@map("withdrawals")
}

// ─────────────────────────────────────────────
// ACCOUNT LOG  — immutable event trail
// event: CREATED | PHASE_CHANGE | WITHDRAWAL | STATUS_CHANGE | NOTE
// ─────────────────────────────────────────────
model AccountLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  accountId String   @map("account_id") @db.Uuid
  event     String                              // CREATED | PHASE_CHANGE | WITHDRAWAL | STATUS_CHANGE | NOTE
  payload   Json     @default("{}")             // flexible: { from, to, amount, note, … }
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt(sort: Desc)])
  @@map("account_logs")
}

model Setup {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  name              String
  abbreviation      String
  market            String   @default("")
  direction         String   @default("AMBAS")
  status            String   @default("ACTIVO")
  description       String   @default("")
  color             String   @default("#4f6ef7")
  images            String[] @default([])
  aplusChecklist    String[] @map("aplus_checklist")
  standardChecklist String[] @map("standard_checklist")
  // ── Edge definition fields (T-VIII-002) ──────
  expectedWr        Decimal? @map("expected_wr")    @db.Decimal(5,2)
  expectedAvgR      Decimal? @map("expected_avg_r") @db.Decimal(5,3)
  minR              Decimal? @map("min_r")          @db.Decimal(5,3)
  maxR              Decimal? @map("max_r")          @db.Decimal(5,3)
  edgeUpdatedAt     DateTime? @map("edge_updated_at") @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]
  linkedResources LearningResource[] @relation("ResourceSetups")
  versions SetupVersion[]

  @@map("setups")
}

model Trade {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  accountId      String   @map("account_id") @db.Uuid
  setupId        String?  @map("setup_id") @db.Uuid
  direction      String
  symbol         String
  entry          Decimal  @db.Decimal(16, 5)
  stop           Decimal  @db.Decimal(16, 5)
  target         Decimal  @db.Decimal(16, 5)
  size           Decimal  @db.Decimal(12, 4)
  date           DateTime @db.Date
  openTime       String   @map("open_time")
  session        String
  tags           String[]
  notes          String   @default("")
  screenshotUrls String[] @map("screenshot_urls")
  rMultiple      Decimal? @map("r_multiple") @db.Decimal(8, 3)
  pnl            Decimal? @db.Decimal(14, 2)
  status         String   @default("OPEN")
  closePrice     Decimal? @map("close_price") @db.Decimal(16, 5)
  closeTime      String?  @map("close_time")
  commission     Decimal? @db.Decimal(10, 2)
  importTicket   String?  @map("import_ticket")
  // ── Psychology fields (Sprint 4, TASK-034) ──────────────
  emotionBefore    String?  @map("emotion_before")    // "calm" | "anxious" | "excited" | "fearful" | "overconfident"
  confidenceRating Int?     @map("confidence_rating") // 1–5
  executionQuality Int?     @map("execution_quality") // 1–5
  fomoFlag         Boolean  @default(false) @map("fomo_flag")
  revengeFlag      Boolean  @default(false) @map("revenge_flag")
  planNotes        String?  @map("plan_notes") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  setup   Setup?       @relation(fields: [setupId], references: [id], onDelete: SetNull)
  events  TradeEvent[]
  embedding TradeEmbedding?

  @@index([userId, date(sort: Desc)])
  @@index([accountId])
  @@map("trades")

  checklistResult TradeChecklistResult?
}

model TradeEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tradeId   String   @map("trade_id") @db.Uuid
  type      String   // STOP_MOVE | PARTIAL_CLOSE | SCALE_IN | NOTE
  price     Decimal? @db.Decimal(16, 5)
  contracts Decimal? @db.Decimal(12, 4)
  notes     String   @default("")
  timestamp DateTime @default(now())

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@map("trade_events")
}

model Rule {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  description String   @default("")
  severity    String   @default("CRÍTICA")
  isSystem    Boolean  @default(false) @map("is_system")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rules")
}

// ─────────────────────────────────────────────
// SETUP VERSION (T-VIII-004)
// Immutable snapshot of a setup before edits to
// versioned fields (aplusChecklist, standardChecklist, direction).
// ─────────────────────────────────────────────
model SetupVersion {
  id        String   @id @default(uuid()) @db.Uuid
  setupId   String   @map("setup_id") @db.Uuid
  version   Int
  snapshot  Json
  reason    String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  setup Setup @relation(fields: [setupId], references: [id], onDelete: Cascade)

  @@unique([setupId, version])
  @@map("setup_versions")
}

model WeeklyReview {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  accountId        String?  @map("account_id") @db.Uuid
  weekLabel        String   @map("week_label")
  weekRange        String   @map("week_range")
  weekStart        DateTime @map("week_start") @db.Date
  weekEnd          DateTime @map("week_end") @db.Date
  tradeCount       Int      @default(0) @map("trade_count")
  netPnl           Decimal  @default(0) @map("net_pnl") @db.Decimal(14, 2)
  winRate          Decimal  @default(0) @map("win_rate") @db.Decimal(5, 2)
  disciplineScore  Int      @default(0) @map("discipline_score")
  executiveSummary String   @default("") @map("executive_summary")
  whatWorked       String   @default("") @map("what_worked")
  toImprove        String   @default("") @map("to_improve")
  status           String   @default("draft")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, weekStart(sort: Desc)])
  @@map("weekly_reviews")
}

model LearningResource {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  title           String
  type            String
  author          String    @default("")
  source          String    @default("")
  date            DateTime  @db.Date
  notes           String    @default("")
  tags            String[]
  markedForReview Boolean   @default(false) @map("marked_for_review")
  progressPct     Int?      @map("progress_pct")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // New fields (TASK-L003)
  status          String    @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | IN_REVIEW | MASTERED | ABANDONED
  progressType    String?   @map("progress_type") // manual | pages | minutes | sessions
  totalUnits      Int?      @map("total_units")
  currentUnits    Int?      @map("current_units")
  avgScore        Decimal?  @map("avg_score") @db.Decimal(5, 2)
  nextReviewAt    DateTime? @map("next_review_at") @db.Date
  reviewInterval  Int?      @map("review_interval")
  isFavorite      Boolean   @default(false) @map("is_favorite")
  rating          Int?
  completedAt     DateTime? @map("completed_at")
  weekDeltaMinutes Int      @default(0) @map("week_delta_minutes")
  weekDeltaResetAt DateTime? @map("week_delta_reset_at")
  archiveReason   String?   @map("archive_reason") // "irrelevant" | "mastered" | "no_time"

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews      ResourceReview[]
  linkedSetups Setup[]          @relation("ResourceSetups")

  @@index([userId, date(sort: Desc)])
  @@map("learning_resources")
}

model ResourceReview {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  resourceId   String   @map("resource_id") @db.Uuid
  learned      String   @default("")
  howToApply   String   @default("") @map("how_to_apply")
  insights     String[]
  rating       Int      @default(0)
  masteryLevel Int      @default(1) @map("mastery_level")
  reviewType   String   @default("manual") @map("review_type")
  nextReviewAt DateTime @db.Date @map("next_review_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([userId, nextReviewAt])
  @@index([resourceId])
  @@map("resource_reviews")
}

model Market {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  symbol        String
  name          String
  category      String
  exchange      String   @default("")
  tickSize      String   @default("") @map("tick_size")
  pointValue    String   @default("") @map("point_value")
  currency      String   @default("USD")
  sessions      String[]
  description   String   @default("")
  isWatchlisted Boolean  @default(false) @map("is_watchlisted")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@map("markets")
}

// ─────────────────────────────────────────────
// TRADE STATS CACHE
// Materialized analytics cache (T-IV-004).
// Keyed by (user_id, period) where period is
// the dashboardStats period enum value.
// TTL enforced at application layer (5 min).
// Feature-flagged via ANALYTICS_CACHE_ENABLED=true.
// ─────────────────────────────────────────────
model TradeStatsCache {
  userId     String   @map("user_id") @db.Uuid
  period     String
  accountId  String?  @map("account_id") @db.Uuid
  statsJson  Json     @map("stats_json")
  computedAt DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, period])
  @@index([userId])
  @@map("trade_stats_cache")
}

// ─────────────────────────────────────────────
// TRADE CHECKLIST RESULT (T-V-003)
// Stores which A+/standard checklist items were
// checked before entering a trade.
// ─────────────────────────────────────────────
model TradeChecklistResult {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  tradeId      String   @unique @map("trade_id") @db.Uuid
  setupId      String?  @map("setup_id") @db.Uuid
  itemsChecked String[] @map("items_checked")
  itemsTotal   Int      @map("items_total")
  createdAt    DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("trade_checklist_results")
}

// ─────────────────────────────────────────────
// TRADING SESSION LOG (T-V-004)
// Pre-session mood and energy ratings (1-5).
// Unique per (user, date, session).
// ─────────────────────────────────────────────
model TradingSessionLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  date        DateTime @db.Date
  session     String
  preMood     Int?     @map("pre_mood")
  energyLevel Int?     @map("energy_level")
  notes       String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, session])
  @@index([userId])
  @@map("trading_sessions")
}

// ─────────────────────────────────────────────
// TRADE EMBEDDING (Phase XIII)
// Tracks embedding vector state per trade. Actual vector stored in pgvector.
// Deferred: EmbeddingService requires UserAiConfig (Phase XI) for key resolution.
// ─────────────────────────────────────────────
model TradeEmbedding {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  tradeId     String   @unique @map("trade_id") @db.Uuid
  model       String
  notesHash   String   @map("notes_hash")
  embeddedAt  DateTime @default(now()) @map("embedded_at")

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("trade_embeddings")
}

// ─────────────────────────────────────────────
// USER PREFERENCES (Sprint 4, TASK-030)
// Per-user UI preferences persisted server-side.
// Created on first update via upsert.
// ─────────────────────────────────────────────
model UserPreferences {
  userId       String   @id @map("user_id") @db.Uuid
  theme        String   @default("system")      // "light" | "dark" | "system"
  accentHue    Int?     @map("accent_hue")      // 0–360 OKLCH
  colorScheme  String   @default("default")     @map("color_scheme") // "default" | "deuteranopia" | "mono"
  defaultTab   String   @default("portfolio")   @map("default_tab")
  kpiOrder     String[] @default([]) @map("kpi_order")
  kpiHidden    String[] @default([]) @map("kpi_hidden")
  defaultGrain String   @default("daily")       @map("default_grain")
  tableDensity String   @default("comfortable") @map("table_density")
  dateFormat   String   @default("DD/MM/YYYY")  @map("date_format")
  numberLocale String   @default("es-HN")       @map("number_locale")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─────────────────────────────────────────────
// EMAIL LOG (Phase XII)
// Prevents duplicate weekly email sends per user/type/week.
// ─────────────────────────────────────────────
model EmailLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emailType String   @map("email_type")
  weekKey   String   @map("week_key")
  sentAt    DateTime @default(now()) @map("sent_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, emailType, weekKey])
  @@map("email_logs")
}

// ─────────────────────────────────────────────
// MONTHLY REVIEW (Sprint 8, TASK-071)
// One review per (user, year, month).
// Aggregates across weekly reviews of that month.
// ─────────────────────────────────────────────
model MonthlyReview {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  year         Int
  month        Int      // 1–12
  summary      String   @default("") @db.Text
  keyThemes    String[] @map("key_themes")
  goalsSet     String[] @map("goals_set")
  goalsMet     String[] @map("goals_met")
  overallScore Int?     @map("overall_score") // 0–100, avg of weekly discipline scores
  weeklyIds    String[] @map("weekly_ids")    // soft refs to WeeklyReview.id
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId, year])
  @@map("monthly_reviews")
}

// ─────────────────────────────────────────────
// USER AI CONFIG (Sprint 5)
// Stores encrypted API keys for AI providers per user.
// Supports anthropic | openrouter | openai.
// apiKeyEnc format: "<iv_hex>:<tag_hex>:<ciphertext_hex>" (AES-256-GCM)
// ─────────────────────────────────────────────
model UserAiConfig {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  provider  String   // "anthropic" | "openrouter" | "openai"
  apiKeyEnc String   @map("api_key_enc")  // AES-256-GCM encrypted: "<iv_hex>:<tag_hex>:<ciphertext_hex>"
  model     String?  // optional model override per provider
  isActive  Boolean  @default(true) @map("is_active")
  lastTested DateTime? @map("last_tested")
  errorLog  String?  @map("error_log")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("user_ai_configs")
}

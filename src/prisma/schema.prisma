generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @db.Uuid
  email              String   @unique
  name               String   @default("")
  role               String   @default("Single-trader")
  timezone           String   @default("America/Tegucigalpa")
  baseCurrency       String   @default("USD") @map("base_currency")
  language           String   @default("es")
  weeklyGoalMinutes  Int?     @default(300) @map("weekly_goal_minutes")
  emailNotifications Boolean  @default(true) @map("email_notifications")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  accounts          Account[]
  setups            Setup[]
  trades            Trade[]
  rules             Rule[]
  weeklyReviews     WeeklyReview[]
  learningResources LearningResource[]
  resourceReviews   ResourceReview[]
  markets           Market[]
  withdrawals       Withdrawal[]
  accountLogs       AccountLog[]
  tradeEvents       TradeEvent[]

  @@map("users")
}

// ─────────────────────────────────────────────
// ACCOUNT
// type:    PERSONAL | PROP_FIRM | DEMO_PERSONAL | DEMO_PROP | BACKTEST | QA
// status:  ACTIVE | PAUSED | INACTIVE | LOST
// ddModel: FIXED | TRAILING  (prop firms only)
// phase:   PHASE_1 | PHASE_2 | FUNDED | NONE
// ─────────────────────────────────────────────
model Account {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String
  broker         String
  type           String   @default("PERSONAL")
  status         String   @default("ACTIVE")                // ACTIVE | PAUSED | INACTIVE | LOST
  statusNote     String   @default("") @map("status_note")  // required note when LOST
  initialBalance Decimal  @default(0) @map("initial_balance") @db.Decimal(14, 2)
  currency       String   @default("USD")
  timezone       String   @default("America/New_York")

  // ── Drawdown limits (all account types) ──────
  ddDailyPct    Decimal? @map("dd_daily_pct")   @db.Decimal(5, 2)
  ddWeeklyPct   Decimal? @map("dd_weekly_pct")  @db.Decimal(5, 2)
  ddMonthlyPct  Decimal? @map("dd_monthly_pct") @db.Decimal(5, 2)
  ddTotalPct    Decimal? @map("dd_total_pct")   @db.Decimal(5, 2)

  // ── Profit target (all account types) ────────
  targetPct     Decimal? @map("target_pct")     @db.Decimal(5, 2)

  // ── Prop Firm extras ──────────────────────────
  ddModel           String?  @default("FIXED")   @map("dd_model")            // FIXED | TRAILING
  phase             String?  @default("PHASE_1") @map("phase")               // PHASE_1 | PHASE_2 | FUNDED | NONE
  maxTradesPerDay   Int?     @map("max_trades_per_day")
  allowedSymbols    String[] @map("allowed_symbols")
  minTradingDays    Int?     @map("min_trading_days")                        // some firms require min days

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades        Trade[]
  weeklyReviews WeeklyReview[]
  withdrawals   Withdrawal[]
  logs          AccountLog[]

  @@index([userId])
  @@map("accounts")
}

// ─────────────────────────────────────────────
// WITHDRAWAL
// status: SOLICITADO | EN_PROCESO | PAGADO | RECHAZADO
// ─────────────────────────────────────────────
model Withdrawal {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  accountId String   @map("account_id") @db.Uuid
  amount    Decimal  @db.Decimal(14, 2)
  currency  String   @default("USD")
  status    String   @default("SOLICITADO")   // SOLICITADO | EN_PROCESO | PAGADO | RECHAZADO
  date      DateTime @db.Date
  note      String   @default("")
  reference String   @default("")              // transaction id / comprobante
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId, date(sort: Desc)])
  @@index([accountId])
  @@map("withdrawals")
}

// ─────────────────────────────────────────────
// ACCOUNT LOG  — immutable event trail
// event: CREATED | PHASE_CHANGE | WITHDRAWAL | STATUS_CHANGE | NOTE
// ─────────────────────────────────────────────
model AccountLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  accountId String   @map("account_id") @db.Uuid
  event     String                              // CREATED | PHASE_CHANGE | WITHDRAWAL | STATUS_CHANGE | NOTE
  payload   Json     @default("{}")             // flexible: { from, to, amount, note, … }
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt(sort: Desc)])
  @@map("account_logs")
}

model Setup {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  name              String
  abbreviation      String
  market            String   @default("")
  direction         String   @default("AMBAS")
  status            String   @default("ACTIVO")
  description       String   @default("")
  color             String   @default("#4f6ef7")
  images            String[] @default([])
  aplusChecklist    String[] @map("aplus_checklist")
  standardChecklist String[] @map("standard_checklist")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]
  linkedResources LearningResource[] @relation("ResourceSetups")

  @@map("setups")
}

model Trade {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  accountId      String   @map("account_id") @db.Uuid
  setupId        String?  @map("setup_id") @db.Uuid
  direction      String
  symbol         String
  entry          Decimal  @db.Decimal(16, 5)
  stop           Decimal  @db.Decimal(16, 5)
  target         Decimal  @db.Decimal(16, 5)
  size           Decimal  @db.Decimal(12, 4)
  date           DateTime @db.Date
  openTime       String   @map("open_time")
  session        String
  tags           String[]
  notes          String   @default("")
  screenshotUrls String[] @map("screenshot_urls")
  rMultiple      Decimal? @map("r_multiple") @db.Decimal(8, 3)
  pnl            Decimal? @db.Decimal(14, 2)
  status         String   @default("OPEN")
  closePrice     Decimal? @map("close_price") @db.Decimal(16, 5)
  closeTime      String?  @map("close_time")
  commission     Decimal? @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  setup   Setup?       @relation(fields: [setupId], references: [id], onDelete: SetNull)
  events  TradeEvent[]

  @@index([userId, date(sort: Desc)])
  @@index([accountId])
  @@map("trades")
}

model TradeEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tradeId   String   @map("trade_id") @db.Uuid
  type      String   // STOP_MOVE | PARTIAL_CLOSE | SCALE_IN | NOTE
  price     Decimal? @db.Decimal(16, 5)
  contracts Decimal? @db.Decimal(12, 4)
  notes     String   @default("")
  timestamp DateTime @default(now())

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@map("trade_events")
}

model Rule {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  name                String
  description         String   @default("")
  severity            String   @default("CRÍTICA")
  isSystem            Boolean  @default(false) @map("is_system")
  enabled             Boolean  @default(true)
  violationsThisMonth Int      @default(0) @map("violations_this_month")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rules")
}

model WeeklyReview {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  accountId        String?  @map("account_id") @db.Uuid
  weekLabel        String   @map("week_label")
  weekRange        String   @map("week_range")
  weekStart        DateTime @map("week_start") @db.Date
  weekEnd          DateTime @map("week_end") @db.Date
  tradeCount       Int      @default(0) @map("trade_count")
  netPnl           Decimal  @default(0) @map("net_pnl") @db.Decimal(14, 2)
  winRate          Decimal  @default(0) @map("win_rate") @db.Decimal(5, 2)
  disciplineScore  Int      @default(0) @map("discipline_score")
  executiveSummary String   @default("") @map("executive_summary")
  whatWorked       String   @default("") @map("what_worked")
  toImprove        String   @default("") @map("to_improve")
  status           String   @default("draft")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, weekStart(sort: Desc)])
  @@map("weekly_reviews")
}

model LearningResource {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  title           String
  type            String
  author          String    @default("")
  source          String    @default("")
  date            DateTime  @db.Date
  notes           String    @default("")
  tags            String[]
  markedForReview Boolean   @default(false) @map("marked_for_review")
  progressPct     Int?      @map("progress_pct")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // New fields (TASK-L003)
  status          String    @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | IN_REVIEW | MASTERED | ABANDONED
  progressType    String?   @map("progress_type") // manual | pages | minutes | sessions
  totalUnits      Int?      @map("total_units")
  currentUnits    Int?      @map("current_units")
  avgScore        Decimal?  @map("avg_score") @db.Decimal(5, 2)
  nextReviewAt    DateTime? @map("next_review_at") @db.Date
  reviewInterval  Int?      @map("review_interval")
  isFavorite      Boolean   @default(false) @map("is_favorite")
  rating          Int?
  completedAt     DateTime? @map("completed_at")
  weekDeltaMinutes Int      @default(0) @map("week_delta_minutes")
  weekDeltaResetAt DateTime? @map("week_delta_reset_at")

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews      ResourceReview[]
  linkedSetups Setup[]          @relation("ResourceSetups")

  @@index([userId, date(sort: Desc)])
  @@map("learning_resources")
}

model ResourceReview {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  resourceId   String   @map("resource_id") @db.Uuid
  learned      String   @default("")
  howToApply   String   @default("") @map("how_to_apply")
  insights     String[]
  rating       Int      @default(0)
  masteryLevel Int      @default(1) @map("mastery_level")
  reviewType   String   @default("manual") @map("review_type")
  nextReviewAt DateTime @db.Date @map("next_review_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([userId, nextReviewAt])
  @@index([resourceId])
  @@map("resource_reviews")
}

model Market {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  symbol        String
  name          String
  category      String
  exchange      String   @default("")
  tickSize      String   @default("") @map("tick_size")
  pointValue    String   @default("") @map("point_value")
  currency      String   @default("USD")
  sessions      String[]
  description   String   @default("")
  isWatchlisted Boolean  @default(false) @map("is_watchlisted")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@map("markets")
}

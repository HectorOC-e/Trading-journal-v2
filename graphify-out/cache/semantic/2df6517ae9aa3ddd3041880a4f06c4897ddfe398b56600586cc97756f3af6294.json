{"nodes": [{"id": "docs_superpowers_specs_2026_07_10_post6_prop_firm_rulebase_design_spec", "label": "POST-6 Prop-Firm Rulebase Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-07-10-post6-prop-firm-rulebase-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_10_post6_prop_firm_rulebase_design_prop_firm_rulebase", "label": "POST-6 Prop-Firm Rulebase (moat)", "file_type": "rationale", "rationale": "Turns each prop firm's rules into a curated central asset: a DB-backed catalog of firm/program/phase presets that auto-configures accounts and feeds enforcement, plus the four missing rule types (trailing DD, consistency, weekend holding, phase progress). Known limitation: enforcement uses realized/journaled equity, not live unrealized P&L.", "source_file": "docs/superpowers/specs/2026-07-10-post6-prop-firm-rulebase-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_10_post6_prop_firm_rulebase_design_snapshot_approach", "label": "Preset Snapshot Approach (A)", "file_type": "rationale", "rationale": "Picking a preset COPIES its values into the account's own fields instead of a live FK reference, because correcting the catalog tomorrow must never silently mutate the limits of a challenge in progress; presetId is kept as audit trace without a hard FK.", "source_file": "docs/superpowers/specs/2026-07-10-post6-prop-firm-rulebase-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_10_post6_prop_firm_rulebase_design_prop_firm_presets_catalog", "label": "prop_firm_presets Global Catalog Table", "file_type": "rationale", "rationale": "Global reference data (no user_id): RLS select for any authenticated user, writes only via service-role (base for a future admin panel). Seeded with 3 anchor firms (FTMO fixed-DD, Topstep trailing+consistency, MyFundedFutures) with sourceUrl/verifiedAt honesty metadata; firm numbers verified by the user before merge.", "source_file": "docs/superpowers/specs/2026-07-10-post6-prop-firm-rulebase-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_10_post6_prop_firm_rulebase_design_enforce_mode", "label": "Account.enforceMode WARN/ENFORCE", "file_type": "rationale", "rationale": "Stored as an Account field mirroring Rule.mode warn|enforce semantics rather than materializing each prop rule as Rule rows (simpler, respects the account's inline model). WARN shows state and lets the trade pass (autonomy, FREEZE-D13); ENFORCE reuses the existing locked mechanism to reject the trade.", "source_file": "docs/superpowers/specs/2026-07-10-post6-prop-firm-rulebase-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "docs_superpowers_specs_2026_07_10_post6_prop_firm_rulebase_design_spec", "target": "docs_architecture_freeze_v31", "relation": "cites", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-10-post6-prop-firm-rulebase-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_07_10_post6_prop_firm_rulebase_design_snapshot_approach", "target": "docs_superpowers_specs_2026_07_10_post6_prop_firm_rulebase_design_prop_firm_presets_catalog", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-10-post6-prop-firm-rulebase-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_07_10_post6_prop_firm_rulebase_design_prop_firm_presets_catalog", "target": "docs_superpowers_specs_2026_07_10_post6_prop_firm_rulebase_de
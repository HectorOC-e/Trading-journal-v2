# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
# Required for prisma migrate (direct connection, bypasses PgBouncer)
# DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Used in Supabase edge functions only (not Next.js)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI Provider Keys (at least one required for AI Coach and Weekly Summary) ──
# Priority: OPENROUTER > ANTHROPIC > OPENAI
OPENROUTER_API_KEY=sk-or-...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── AI Model Overrides (optional — defaults to latest Claude models) ───────────
# AI_COACH_MODEL=claude-sonnet-4-6
# WEEKLY_SUMMARY_MODEL=claude-haiku-4-5-20251001
# EMBEDDING_MODEL=openai/text-embedding-3-small

# ── Supabase Edge Function Secrets ────────────────────────────────────────────
# Set in Supabase Dashboard > Edge Functions > Secrets (not in .env file)
RESEND_API_KEY=re_...
CRON_SECRET=your-random-cron-secret

# ── Feature Flags (optional) ──────────────────────────────────────────────────
# ANALYTICS_CACHE_ENABLED=true
